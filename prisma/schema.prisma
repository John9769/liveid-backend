generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum HandleTier {
  STANDARD
  SPECIAL
  SILVER
  GOLDEN
}

enum HandleStatus {
  AVAILABLE
  ACTIVE
  RETIRED
}

enum UserTier {
  STANDARD
  PREMIUM_VARIANT
  VAULT
}

enum TransactionType {
  REGISTRATION
  RENEWAL
  VAULT_PURCHASE
  VAULT_RENEWAL
  PREMIUM_PURCHASE
  PREMIUM_RENEWAL
  REFERRAL_PAYOUT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum VaultHandleTier {
  VAULT
  VAULT_VARIANT
}

enum VaultHandleStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum VaultOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
}

enum WaitlistType {
  TAKEN_HANDLE
  WISH_REQUEST
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CLAIMED
  EXPIRED
}

enum CelebrityStatus {
  PROSPECT
  CONTACTED
  NEGOTIATING
  CLOSED
  DECLINED
}

enum CelebrityHandleStatus {
  RESERVED
  ACTIVE
  EXPIRED
}

enum ReferralEarningType {
  STANDARD_REG
  STANDARD_RENEWAL
  VAULT_PURCHASE
  VAULT_RENEWAL
  PREMIUM_PURCHASE
  PREMIUM_RENEWAL
  OVERRIDE_STANDARD_REG
  OVERRIDE_STANDARD_RENEWAL
  OVERRIDE_VAULT_PURCHASE
  OVERRIDE_VAULT_RENEWAL
}

enum PricingKey {
  REGISTRATION_FEE
  STANDARD_HANDLE_BASE
  ANNUAL_RENEWAL
  REFERRAL_STANDARD_REG
  REFERRAL_STANDARD_RENEWAL
  REFERRAL_VAULT_PERCENT
  GATEWAY_FEE
  VAULT_RENEWAL_PERCENT
  SUPER_REFERRAL_STANDARD_REG
  SUPER_REFERRAL_STANDARD_RENEWAL
  SUPER_REFERRAL_VAULT_PERCENT
}

// ============================================================
// CORE USER
// ============================================================

model User {
  id                  String    @id @default(uuid())
  genericId           String    @unique
  phone               String    @unique
  email               String    @unique
  passwordHash        String
  faceId              String    @unique

  // Tier
  tier                UserTier  @default(STANDARD)

  // Verification
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?

  // Annual renewal
  registrationExpiry  DateTime?
  renewalAmount       Float?

  // Referral tracking
  referralCode        String?

  // Password reset
  resetToken          String?
  resetTokenExpiry    DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  handleRequests      HandleRequest[]
  transactions        Transaction[]
  activeHandle        Handle?          @relation("ActiveHandle")
  profile             UserProfile?
  trustScore          TrustScore?
  vaultHandle         VaultHandle?     @relation("VaultOwner")
  celebrityHandle     CelebrityHandle? @relation("CelebrityHandleOwner")
}

// ============================================================
// HANDLES
// ============================================================

model HandleRequest {
  id          String   @id @default(uuid())
  handleName  String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([handleName])
}

model Handle {
  id              String       @id @default(uuid())
  name            String       @unique
  baseWord        String
  numberSuffix    String?
  tier            HandleTier
  price           Float
  status          HandleStatus @default(AVAILABLE)

  // Vault flag
  isVault         Boolean      @default(false)
  isVaultVariant  Boolean      @default(false)

  ownerId         String?      @unique
  owner           User?        @relation("ActiveHandle", fields: [ownerId], references: [id])

  handleHash      String?      @unique
  retiredAt       DateTime?
  createdAt       DateTime     @default(now())
}

model CuratedWord {
  id                String     @id @default(uuid())
  word              String     @unique
  tier              HandleTier
  basePrice         Float

  // Vault classification
  isVault           Boolean    @default(false)
  vaultPrice        Float?
  vaultRenewalFee   Float?
  vaultVariantPrice Float?

  createdAt         DateTime   @default(now())
}

// ============================================================
// VAULT HANDLES
// ============================================================

model VaultHandle {
  id            String            @id @default(uuid())
  name          String            @unique
  tier          VaultHandleTier
  baseWord      String
  buyNowPrice   Float
  reservePrice  Float
  renewalFee    Float
  status        VaultHandleStatus @default(AVAILABLE)

  ownerId       String?           @unique
  owner         User?             @relation("VaultOwner", fields: [ownerId], references: [id])

  soldAt        DateTime?
  createdAt     DateTime          @default(now())

  offers        VaultOffer[]
}

model VaultOffer {
  id              String           @id @default(uuid())
  vaultHandleId   String
  vaultHandle     VaultHandle      @relation(fields: [vaultHandleId], references: [id])

  name            String
  phone           String
  email           String
  offerAmount     Float
  message         String?
  status          VaultOfferStatus @default(PENDING)
  counterAmount   Float?

  createdAt       DateTime         @default(now())
}

// ============================================================
// TRANSACTIONS
// ============================================================

model Transaction {
  id                  String            @id @default(uuid())
  userId              String?
  user                User?             @relation(fields: [userId], references: [id])

  type                TransactionType   @default(REGISTRATION)
  status              TransactionStatus @default(PENDING)
  amountRM            Float

  handleId            String?
  toyyibRef           String?
  pendingData         Json?

  // Referral tracking
  referralCode        String?
  referralCommission  Float?

  createdAt           DateTime          @default(now())

  referralEarning     ReferralEarning?
}

// ============================================================
// REFERRAL SYSTEM
// ============================================================

model Referral {
  id              String    @id @default(uuid())
  name            String
  code            String?   @unique  // nullable — Super Referral only may not need a code
  phone           String
  email           String

  // Bank details for payout
  bankName        String?
  bankAccount     String?
  bankAccountName String?

  // Referral type flags
  isActiveReferral    Boolean   @default(true)   // has own referral link, earns direct commission
  isSuperReferral     Boolean   @default(false)  // can recruit referrals, earns override commission

  // Super Referral network — self referencing
  superReferralId     String?
  superReferral       Referral?  @relation("SuperReferralNetwork", fields: [superReferralId], references: [id])
  subReferrals        Referral[] @relation("SuperReferralNetwork")

  // Follower count for records
  minFollowers        Int?

  // Direct earnings
  totalEarnings       Float     @default(0)
  totalPaid           Float     @default(0)

  // Override earnings — separate tracking
  totalOverrideEarnings Float   @default(0)
  totalOverridePaid     Float   @default(0)

  isActive            Boolean   @default(true)
  invitedBy           String    @default("admin")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  earnings            ReferralEarning[] @relation("DirectEarnings")
  overrideEarnings    ReferralEarning[] @relation("OverrideEarnings")
}

model ReferralEarning {
  id              String              @id @default(uuid())

  // Direct referral
  referralId      String
  referral        Referral            @relation("DirectEarnings", fields: [referralId], references: [id])

  transactionId   String              @unique
  transaction     Transaction         @relation(fields: [transactionId], references: [id])

  userId          String?
  amount          Float
  type            ReferralEarningType

  // Override commission fields
  isOverride          Boolean   @default(false)
  overrideReferralId  String?   // Super Referral who gets the override
  overrideReferral    Referral? @relation("OverrideEarnings", fields: [overrideReferralId], references: [id])
  overrideAmount      Float?    // how much the Super Referral earns

  isPaid          Boolean             @default(false)
  paidAt          DateTime?
  overrideIsPaid  Boolean             @default(false)
  overridePaidAt  DateTime?

  createdAt       DateTime            @default(now())
}

// ============================================================
// USER PROFILE
// ============================================================

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  displayName String?
  bio         String?
  photoUrl    String?
  city        String?
  profession  String?

  // Social media links
  instagram   String?
  tiktok      String?
  facebook    String?
  twitter     String?
  youtube     String?
  whatsapp    String?
  website     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// TRUST SCORE
// ============================================================

model TrustScore {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])

  score         Int      @default(0)
  factors       Json?
  calculatedAt  DateTime @default(now())
}

// ============================================================
// WAITLIST
// ============================================================

model Waitlist {
  id          String         @id @default(uuid())
  type        WaitlistType
  handleName  String
  name        String
  phone       String
  email       String
  userId      String?
  status      WaitlistStatus @default(WAITING)
  notifiedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([handleName])
}

// ============================================================
// CELEBRITY PIPELINE
// ============================================================

model Celebrity {
  id                  String          @id @default(uuid())
  name                String
  phone               String?
  email               String?

  // Social media reach
  instagram           String?
  instagramFollowers  Int?
  tiktok              String?
  tiktokFollowers     Int?
  facebook            String?
  facebookFollowers   Int?
  totalReach          Int?

  // Deal details
  proposedHandle      String?
  proposedPrice       Float?
  renewalFee          Float?
  status              CelebrityStatus @default(PROSPECT)
  notes               String?

  // Network
  introducedBy        String?
  referralId          String?

  // Deal closing
  dealClosedAt        DateTime?
  contractValue       Float?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  handles             CelebrityHandle[]
}

model CelebrityHandle {
  id            String                @id @default(uuid())
  celebrityId   String
  celebrity     Celebrity             @relation(fields: [celebrityId], references: [id])

  handleName    String                @unique
  purchasePrice Float?
  renewalFee    Float?
  status        CelebrityHandleStatus @default(RESERVED)

  ownerId       String?               @unique
  owner         User?                 @relation("CelebrityHandleOwner", fields: [ownerId], references: [id])

  reservedAt    DateTime?
  activatedAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime              @default(now())
}

// ============================================================
// PRICING CONFIG
// ============================================================

model PricingConfig {
  id          String     @id @default(uuid())
  value       Float
  description String?
  updatedAt   DateTime   @updatedAt

  key         PricingKey @unique
}