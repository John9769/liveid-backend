generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum HandleTier {
  STANDARD
  SPECIAL
  SILVER
  GOLDEN
  TITLE
}

enum HandleStatus {
  AVAILABLE
  ACTIVE
  RETIRED
}

enum UserTier {
  STANDARD
  PREMIUM_VARIANT
  TITLE
}

enum TransactionType {
  REGISTRATION
  RENEWAL
  PREMIUM_PURCHASE
  PREMIUM_RENEWAL
  TITLE_PURCHASE
  TITLE_RENEWAL
  REFERRAL_PAYOUT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BlockedCategory {
  TITLE
  REAL_NAME
}

enum TitleRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  EXPIRED
}

enum WaitlistType {
  TAKEN_HANDLE
  WISH_REQUEST
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CLAIMED
  EXPIRED
}

enum CelebrityStatus {
  PROSPECT
  CONTACTED
  NEGOTIATING
  CLOSED
  DECLINED
}

enum CelebrityHandleStatus {
  RESERVED
  ACTIVE
  EXPIRED
}

enum ReferralEarningType {
  STANDARD_REG
  STANDARD_RENEWAL
  PREMIUM_PURCHASE
  PREMIUM_RENEWAL
  TITLE_PURCHASE
  TITLE_RENEWAL
  OVERRIDE_STANDARD_REG
  OVERRIDE_STANDARD_RENEWAL
  OVERRIDE_PREMIUM_PURCHASE
  OVERRIDE_TITLE_PURCHASE
}

enum PricingKey {
  REGISTRATION_FEE
  STANDARD_HANDLE_BASE
  CURATED_ADDON
  ANNUAL_RENEWAL
  RENEWAL_SPECIAL
  RENEWAL_SILVER
  RENEWAL_GOLDEN
  TITLE_RENEWAL_PERCENT
  GATEWAY_FEE
  REFERRAL_STANDARD_REG
  REFERRAL_STANDARD_RENEWAL
  REFERRAL_PREMIUM_PERCENT
  REFERRAL_TITLE_PERCENT
  SUPER_REFERRAL_STANDARD_REG
  SUPER_REFERRAL_STANDARD_RENEWAL
  SUPER_REFERRAL_PREMIUM_PERCENT
  SUPER_REFERRAL_TITLE_PERCENT
}

// ============================================================
// CORE USER
// ============================================================

model User {
  id                  String    @id @default(uuid())
  genericId           String    @unique
  phone               String    @unique
  email               String    @unique
  passwordHash        String
  faceId              String    @unique

  tier                UserTier  @default(STANDARD)

  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?

  registrationExpiry  DateTime?
  renewalAmount       Float?

  referralCode        String?

  resetToken          String?
  resetTokenExpiry    DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  handleRequests      HandleRequest[]
  transactions        Transaction[]
  activeHandle        Handle?          @relation("ActiveHandle")
  profile             UserProfile?
  trustScore          TrustScore?
  titleRequests       TitleRequest[]
  shopItems           ShopItem[]
  celebrityHandle     CelebrityHandle? @relation("CelebrityHandleOwner")
}

// ============================================================
// HANDLES
// ============================================================

model HandleRequest {
  id          String   @id @default(uuid())
  handleName  String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([handleName])
}

model Handle {
  id              String       @id @default(uuid())
  name            String       @unique
  baseWord        String
  numberSuffix    String?
  tier            HandleTier
  price           Float
  status          HandleStatus @default(AVAILABLE)

  isTitle         Boolean      @default(false)

  ownerId         String?      @unique
  owner           User?        @relation("ActiveHandle", fields: [ownerId], references: [id])

  handleHash      String?      @unique
  retiredAt       DateTime?
  createdAt       DateTime     @default(now())
}

model CuratedWord {
  id          String     @id @default(uuid())
  word        String     @unique
  tier        HandleTier
  basePrice   Float
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

model BlockedWord {
  id          String          @id @default(uuid())
  word        String          @unique
  category    BlockedCategory
  reason      String?
  createdAt   DateTime        @default(now())

  @@index([category])
}

// ============================================================
// TITLES
// ============================================================

model TitlePrice {
  id          String   @id @default(uuid())
  title       String   @unique
  label       String
  price       Float
  renewalFee  Float
  requiresDoc Boolean  @default(true)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TitleRequest {
  id             String             @id @default(uuid())
  userId         String?
  user           User?              @relation(fields: [userId], references: [id])

  handleName     String
  fullName       String
  phone          String
  email          String

  title          String
  awardYear      Int?
  awardBody      String?
  documentUrl    String

  status         TitleRequestStatus @default(PENDING)
  approvedPrice  Float?
  renewalFee     Float?
  adminNotes     String?
  reviewedAt     DateTime?

  toyyibRef      String?
  paidAt         DateTime?

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([handleName])
  @@index([status])
}

// ============================================================
// SEARCH LOG
// ============================================================

model SearchLog {
  id           String   @id @default(uuid())
  query        String
  matchedWord  String?
  tier         String?
  price        Float?
  available    Boolean?
  blocked      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}

// ============================================================
// TRANSACTIONS
// ============================================================

model Transaction {
  id                  String            @id @default(uuid())
  userId              String?
  user                User?             @relation(fields: [userId], references: [id])

  type                TransactionType   @default(REGISTRATION)
  status              TransactionStatus @default(PENDING)
  amountRM            Float

  handleId            String?
  toyyibRef           String?
  pendingData         Json?

  referralCode        String?
  referralCommission  Float?

  createdAt           DateTime          @default(now())

  referralEarning     ReferralEarning?
}

// ============================================================
// REFERRAL SYSTEM
// ============================================================

model Referral {
  id              String    @id @default(uuid())
  name            String
  code            String?   @unique
  phone           String
  email           String

  bankName        String?
  bankAccount     String?
  bankAccountName String?

  isActiveReferral      Boolean   @default(true)
  isSuperReferral       Boolean   @default(false)

  superReferralId       String?
  superReferral         Referral?  @relation("SuperReferralNetwork", fields: [superReferralId], references: [id])
  subReferrals          Referral[] @relation("SuperReferralNetwork")

  minFollowers          Int?

  totalEarnings         Float     @default(0)
  totalPaid             Float     @default(0)

  totalOverrideEarnings Float     @default(0)
  totalOverridePaid     Float     @default(0)

  isActive              Boolean   @default(true)
  invitedBy             String    @default("admin")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  earnings              ReferralEarning[] @relation("DirectEarnings")
  overrideEarnings      ReferralEarning[] @relation("OverrideEarnings")
}

model ReferralEarning {
  id              String              @id @default(uuid())

  referralId      String
  referral        Referral            @relation("DirectEarnings", fields: [referralId], references: [id])

  transactionId   String              @unique
  transaction     Transaction         @relation(fields: [transactionId], references: [id])

  userId          String?
  amount          Float
  type            ReferralEarningType

  isOverride          Boolean   @default(false)
  overrideReferralId  String?
  overrideReferral    Referral? @relation("OverrideEarnings", fields: [overrideReferralId], references: [id])
  overrideAmount      Float?

  isPaid          Boolean             @default(false)
  paidAt          DateTime?
  overrideIsPaid  Boolean             @default(false)
  overridePaidAt  DateTime?

  createdAt       DateTime            @default(now())
}

// ============================================================
// USER PROFILE
// ============================================================

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  displayName String?
  bio         String?
  photoUrl    String?
  photoPublic Boolean  @default(false)
  city        String?
  profession  String?

  instagram   String?
  tiktok      String?
  facebook    String?
  twitter     String?
  youtube     String?
  whatsapp    String?
  website     String?

  // Shop
  shopActive  Boolean  @default(false)
  shopTitle   String?
  shopArea    String?
  shopAbout   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// SHOP
// ============================================================

model ShopItem {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  name        String
  price       String?
  detail      String?
  hasImages   Boolean  @default(false)
  isAvailable Boolean  @default(true)

  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ============================================================
// TRUST SCORE
// ============================================================

model TrustScore {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])

  score         Int      @default(0)
  factors       Json?
  calculatedAt  DateTime @default(now())
}

// ============================================================
// WAITLIST
// ============================================================

model Waitlist {
  id          String         @id @default(uuid())
  type        WaitlistType
  handleName  String
  name        String
  phone       String
  email       String
  userId      String?
  status      WaitlistStatus @default(WAITING)
  notifiedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([handleName])
}

// ============================================================
// CELEBRITY PIPELINE
// ============================================================

model Celebrity {
  id                  String          @id @default(uuid())
  name                String
  phone               String?
  email               String?

  instagram           String?
  instagramFollowers  Int?
  tiktok              String?
  tiktokFollowers     Int?
  facebook            String?
  facebookFollowers   Int?
  totalReach          Int?

  proposedHandle      String?
  proposedPrice       Float?
  renewalFee          Float?
  status              CelebrityStatus @default(PROSPECT)
  notes               String?

  introducedBy        String?
  referralId          String?

  dealClosedAt        DateTime?
  contractValue       Float?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  handles             CelebrityHandle[]
}

model CelebrityHandle {
  id            String                @id @default(uuid())
  celebrityId   String
  celebrity     Celebrity             @relation(fields: [celebrityId], references: [id])

  handleName    String                @unique
  purchasePrice Float?
  renewalFee    Float?
  status        CelebrityHandleStatus @default(RESERVED)

  ownerId       String?               @unique
  owner         User?                 @relation("CelebrityHandleOwner", fields: [ownerId], references: [id])

  reservedAt    DateTime?
  activatedAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime              @default(now())
}

// ============================================================
// PRICING CONFIG
// ============================================================

model PricingConfig {
  id          String     @id @default(uuid())
  value       Float
  description String?
  updatedAt   DateTime   @updatedAt

  key         PricingKey @unique
}

// ============================================================
// VERIFY LOG
// ============================================================

model VerifyLog {
  id          String   @id @default(uuid())
  handleName  String
  viewerId    String?
  ip          String?
  userAgent   String?
  referer     String?
  createdAt   DateTime @default(now())

  @@index([handleName])
  @@index([viewerId])
  @@index([createdAt])
}

// ============================================================
// ADMIN
// ============================================================

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================================
// INVITATION
// ============================================================

model Invitation {
  id              String   @id @default(uuid())
  token           String   @unique
  email           String
  phone           String
  name            String
  handle          String
  role            String
  superReferralId String?
  bankName        String?
  bankAccount     String?
  bankAccountName String?
  isUsed          Boolean  @default(false)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}